# Skopiuj: cp .env.example .env  (Windows: copy .env.example .env)
# Next.js ładuje .env przy pnpm dev / pnpm build.

# --- Serwer (server.js) ---
PORT=3000
HOSTNAME=0.0.0.0

# --- SEO / meta / sitemap (Next.js, publiczne w bundle) ---
NEXT_PUBLIC_SITE_URL=https://pliki.vxh.pl

# --- Dev/staging (CapRover dev app: pliki-vxh-pl-developer.vpsskull.vxh.pl) ---
# NEXT_PUBLIC_DEV_BANNER=1
# NEXT_PUBLIC_OFFICIAL_SITE_URL=https://pliki.vxh.pl

# --- Licznik odwiedzin (plik visits.json) ---
# Dev: katalog data/ w projekcie. Docker/CapRover: /app/data + Persistent Directory.
# VISIT_DATA_DIR=data

# NODE_ENV ustawiają skrypty (dev / production) — zwykle nie zmieniaj ręcznie.
